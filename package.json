{
  "name": "mathable",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "install-all": "npm install --workspaces",
    "start:client": "npm run start --workspace=client",
    "start:server": "npm run dev --workspace=server",
